# ============================================================
#  SoulSync — Frontend Environment Variables
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
#
#  All variables MUST start with VITE_ to be exposed to the
#  browser bundle by Vite.
# ============================================================


# ------------------------------------------------------------
#  Backend API
#  URL of the running Express backend (no trailing slash).
#  For production point this to your deployed backend URL.
# ------------------------------------------------------------

VITE_BACKEND_URL=http://localhost:4000


# ------------------------------------------------------------
#  Google OAuth
#  Must match the GOOGLE_CLIENT_ID in backend/.env exactly.
#  Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# ------------------------------------------------------------

VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com


# ------------------------------------------------------------
#  JioSaavn API (optional — override the default public mirror)
#  Default: https://jiosaavn.rajputhemant.dev
# ------------------------------------------------------------

VITE_JIOSAAVN_API=https://jiosaavn.rajputhemant.dev


# ------------------------------------------------------------
#  Duo / Socket.io backend
#  Should point to the same backend as VITE_BACKEND_URL.
#  Kept separate so you can route sockets to a dedicated
#  server in production if needed.
# ------------------------------------------------------------

VITE_DUO_BACKEND=http://localhost:4000
