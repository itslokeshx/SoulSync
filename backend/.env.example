# ============================================================
#  SoulSync — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# ============================================================


# ------------------------------------------------------------
#  Server
# ------------------------------------------------------------

# Port the Express server listens on
PORT=4000

# Environment: development | production
NODE_ENV=development

# Exact origin of your frontend (no trailing slash)
FRONTEND_URL=http://localhost:5173


# ------------------------------------------------------------
#  MongoDB Atlas
#  1. Create a free M0 cluster at https://cloud.mongodb.com
#  2. Database Access → add user with readWrite role
#  3. Network Access → allow 0.0.0.0/0 (or your IP)
#  4. Connect → Drivers → copy the connection string
# ------------------------------------------------------------

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/soulsync?retryWrites=true&w=majority


# ------------------------------------------------------------
#  Authentication
#  Generate a secret with:
#  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------

JWT_SECRET=replace_with_your_64_char_hex_secret

# Google OAuth Client ID
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com


# ------------------------------------------------------------
#  Groq AI (https://console.groq.com)
#  Add up to 5 keys for automatic round-robin rotation.
#  At least GROQ_KEY_1 is required for AI playlist features.
# ------------------------------------------------------------

GROQ_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_KEY_5=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
#  Upstash Redis (optional — rate-limiting & session cache)
#  If left empty the app falls back to an in-memory store.
#  https://console.upstash.com → Create Database → REST API
# ------------------------------------------------------------

UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
#  JioSaavn API (optional — override the default public mirror)
#  Default: https://jiosaavn.rajputhemant.dev
# ------------------------------------------------------------

# JIOSAAVN_API=https://jiosaavn.rajputhemant.dev
